# Supabase Edge Functions Environment Variables
# Copy this file to .env and fill in the values

# Hugging Face API key (required for AI interviews)
# Get your key from https://huggingface.co/settings/tokens
HF_API_KEY=hf_your_api_key_here

# Email sending via Brevo (required for interview result emails)
# Get your API key from https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here

# The "From" email address shown to recipients
# Must be a verified sender in your Brevo account
EMAIL_FROM_ADDRESS=noreply@interviewai.app

# Your app's public URL (used in email CTA button)
APP_URL=http://localhost:8080
