# Interview AI — Backend Environment Variables
# Copy this file to .env and fill in your values

# Port the Express server listens on (default: 3001)
PORT=3001

# Brevo (Sendinblue) API key — required for sending emails
# Get yours at: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here

# The "From" address shown to email recipients
# Must be a verified sender in your Brevo account
EMAIL_FROM_ADDRESS=noreply@interviewai.app

# Your frontend app's public URL (used in the email CTA button)
APP_URL=http://localhost:8080

# Allowed CORS origin (set to your frontend URL in production)
ALLOWED_ORIGIN=http://localhost:8080
